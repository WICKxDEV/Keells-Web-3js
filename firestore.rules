rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Collection Rules ---

    match /products/{productId} {
      allow read, write: if true;
    }

    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /test/connection {
      allow read, write: if true;
    }

    // --- Helpers (for future use) ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "isuruwickramasinghe.sliate@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Rest of the collections ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 0. Default Deny (Last resort)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
