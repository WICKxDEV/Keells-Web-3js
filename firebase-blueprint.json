{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user profile data shared by customers and staff.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "manager", "staff", "rider"] },
        "loyaltyPoints": { "type": "number" },
        "addresses": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Available grocery and retail items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "image": { "type": "string" },
        "gallery": { "type": "array", "items": { "type": "string" } },
        "sku": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "nutritionalData": { "type": "object" },
        "ratings": { "type": "number" },
        "reviewCount": { "type": "number" }
      },
      "required": ["id", "name", "price", "category", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product hierarchy and navigation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "deliveryAddress": { "type": "object" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid", "refunded"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deliveryRiderId": { "type": "string" },
        "estimatedDelivery": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Marketing banners and flash sales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "discountCode": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["title", "imageUrl", "isActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog items."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/promotions/{promoId}": {
      "schema": "Promotion",
      "description": "Active marketing promotions."
    }
  }
}
